# MongoDB Configuration
MONGO_URI=mongodb://127.0.0.1:27017/stockwebsite

# Server Configuration
PORT=3000

# JWT Configuration
JWT_SECRET=stockedge_secret_2024
TEMP_TOKEN_SECRET=stockedge_temp_2024

# Email Configuration (SMTP)
# Using Ethereal (test service) by default for development
# For production, use your actual email service (Gmail, SendGrid, AWS SES, etc.)
SMTP_HOST=smtp.ethereal.email
SMTP_PORT=587
EMAIL_USER=your-ethereal-email@ethereal.email
EMAIL_PASS=your-ethereal-password

# For Gmail SMTP (requires App Password):
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# EMAIL_USER=your-email@gmail.com
# EMAIL_PASS=your-app-password

# For SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# EMAIL_USER=apikey
# EMAIL_PASS=SG.your-sendgrid-api-key

# Twilio SMS settings
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_FROM_NUMBER=+1234567890
